# =============== Custom Functions ===============
mkcd() { mkdir -p "$1" && cd "$1" || return; }

extract() {
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1"     ;;
            *.tar.gz)    tar xzf "$1"     ;;
            *.bz2)       bunzip2 "$1"     ;;
            *.rar)       unrar e "$1"     ;;
            *.gz)        gunzip "$1"      ;;
            *.tar)       tar xf "$1"      ;;
            *.tbz2)      tar xjf "$1"     ;;
            *.tgz)       tar xzf "$1"     ;;
            *.zip)       unzip "$1"       ;;
            *.Z)         uncompress "$1"  ;;
            *.7z)        7z x "$1"        ;;
            *)     echo "'$1' cannot be extracted via extract()" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

tar_max() {
  tar --exclude='.DS_Store' \
      --exclude='__MACOSX' \
      --exclude='node_modules' \
      --exclude='__pycache__' \
      --exclude='*.pyc' \
      -cv "$1" | xz -3e > "$2".tar.xz
}

grep_this() {
  command grep --color -inrw . -e "$1"
  echo "Matches: $(command grep -inrw . -e "$1" | wc -l)"
}

mkdir_date() {
  mkdir -p "$(date '+%Y-%h-%d-%a')"
}

kill_spaces() {
  command find . -name "*.$1" -type f -print0 | while IFS= read -r -d $'\0' f; do mv -v "$f" "${f// /_}"; done
}

encrypt_pdf() {
  encrypted_pdf="${1%.pdf}.128.pdf"
  pdftk "$1" output "${encrypted_pdf}" owner_pw "$2" allow printing verbose
  mv -v "$1" "${1%.pdf}_src.pdf"
  mv -v "${encrypted_pdf}" "${encrypted_pdf%.128.pdf}.pdf"
}

split_pdf() {
  split_files="${1%.pdf}_%02d.pdf"
  pdftk "$1" burst output "${split_files}" verbose
}

grep_pdf() {
  fd -H -t f -e pdf . | while IFS= read -r filename; do
    pdftotext -enc Latin1 "$filename" - | rg --color always -i "$1" | sed "s/^/$filename: /"
  done
}

rgf() {
  rg --color=always --line-number "$@" \
    | fzf --ansi --delimiter=: \
          --preview 'bat --color=always {1} --highlight-line {2}' \
          --preview-window 'right:60%:+{2}-3'
}

diff() {
  command diff --color=always "$@" | delta
}

py_version() {
  yq '.tool.poetry.dependencies.python' pyproject.toml
}

function add_nodemodules_bin() {
  local bin_path="./node_modules/.bin"
  if [[ -d "$bin_path" && ":$PATH:" != *":$bin_path:"* ]]; then
    export PATH="$bin_path:$PATH"
  fi
}
autoload -U add-zsh-hook
add-zsh-hook chpwd add_nodemodules_bin

# =============== macOS-only Functions ===============
compress_audio() {
  if [ $# -eq 0 ]; then
    echo "Usage: compress_audio <input_file> [output_file]"
    return 1
  fi
  local input_file="$1"
  local output_file="${2:-compressed_${input_file}}"
  if [ ! -f "$input_file" ]; then
    echo "Error: '$input_file' not found"
    return 1
  fi
  ffmpeg -i "$input_file" -codec:a libmp3lame -q:a 7 "$output_file"
}

days_until() {
  local date_cmd
  date_cmd="$(command -v gdate || command -v date)"
  local target
  target="$($date_cmd -d "$1" +%s 2>/dev/null)"
  if [ -z "$target" ]; then
    echo "Error: invalid date format"
    return 1
  fi
  local now
  now="$($date_cmd +%s)"
  echo "$target $now" | awk '{diff=($1-$2)/86400; printf "%.0f days from now\n", diff}'
}

wget_entire_site() {
  wget --continue --mirror --convert-links --adjust-extension --page-requisites --no-parent "$1"
}

