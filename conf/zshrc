# shellcheck shell=bash
# =============== Keybindings ===============
bindkey -e  # emacs key bindings
# Word movement (both Ctrl+Arrow and Alt+Arrow codes for Kitty on macOS)
bindkey '^[[1;5C' vi-forward-word    # Ctrl+Right (Linux/Kitty)
bindkey '^[[1;5D' vi-backward-word   # Ctrl+Left
bindkey '^[[1;3C' vi-forward-word    # Alt+Right (macOS terminal)
bindkey '^[[1;3D' vi-backward-word   # Alt+Left
bindkey '^[f' vi-forward-word        # Alt+f (emacs style)
bindkey '^[b' vi-backward-word       # Alt+b
bindkey '^[[H' beginning-of-line     # Home
bindkey '^[[F' end-of-line           # End

# =============== Options ===============
setopt autocd
setopt extendedglob
setopt interactivecomments
setopt magicequalsubst
setopt notify
setopt numericglobsort
setopt promptsubst
setopt sharehistory

# =============== History ===============
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt extended_history
setopt appendhistory
setopt incappendhistory
setopt histignorealldups
setopt histignoredups
setopt histignorespace
setopt histreduceblanks

history() {
    if [[ $# -eq 0 ]]; then
        builtin history -i 1
    else
        builtin history "$@"
    fi
}

